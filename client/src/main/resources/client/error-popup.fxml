            <Insets left="15.0" right="15.0" top="15.0" />
         </GridPane.margin>
         <font>
            <Font name="Times New Roman" size="14.0" />
         </font>
      </TextArea>
      <Button mnemonicParsing="false" onAction="#closeButtonPressed" text="CLOSE" underline="true" GridPane.halignment="CENTER" GridPane.rowIndex="1">
         <font>
            <Font name="Times New Roman" size="18.0" />
         </font>
         <GridPane.margin>
            <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
         </GridPane.margin>
